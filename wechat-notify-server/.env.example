# 侧边待办 微信提醒后端 · 环境变量样例
# 复制为 .env 并填入真实值（.env 已 gitignore，切勿提交）

# 后端监听端口（内网，由 nginx 反代到 https）
PORT=9528

# ===== 微信认证服务号 =====
# 公众平台 → 设置与开发 → 基本配置
WECHAT_APPID=
WECHAT_APPSECRET=
# 服务器配置里你自己设定的 Token（与公众平台填的必须一致）
WECHAT_TOKEN=
# 模板消息库里你申请的模板 ID
WECHAT_TEMPLATE_ID=

# app 调本后端 API 的鉴权 key（app 与后端两边填一致）
API_KEY=change-me

# 数据存储文件（轻量 JSON 持久化）
DATA_FILE=./data/store.json

# 模板消息点击后跳转的详情页基址（可留空）
DETAIL_BASE_URL=
